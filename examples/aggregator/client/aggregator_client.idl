
!@sails: 1.0.0-beta.5

service Aggregator@0x4fe37e07a040ac29 {
    functions {
        BenchTracker(op: TrackerOp, seed: u32) -> TrackerBenchResult;
        ComplexAdd() -> Result<u32, String>;
        @query
        FetchFastest(target: ActorId) -> Result<u32, String>;
        @query
        FetchFromAddress(target: ActorId) -> Result<u32, String>;
        @query
        FetchRedirectId(target: ActorId) -> Result<ActorId, String>;
        @query
        FetchSummary() -> Result<(u32, u32), String>;
        @query
        FetchValue() -> Result<u32, String>;
        @query
        FetchWithFallback(use_fallback: bool) -> Result<u32, String>;
        @query
        GetStatuses() -> [(MessageId, OpStatus)];
        PrepareTracker(len: u32) -> TrackerBenchResult;
        @query
        TestPollAfterCompletion();
    }
    types {
        enum OpStatus {
            Started,
            Step1,
            Step2,
            Finalized,
        }
        struct TrackerBenchResult {
            len: u32,
            status: Option<OpStatus>,
            existed: bool,
        }
        enum TrackerOp {
            InsertFresh,
            UpdateExisting,
            ReadExisting,
            ListStatuses,
        }
    }
}

program AggregatorClient {
    constructors {
        New(target: ActorId);
        NewWithTracker(target: ActorId, tracker_backend: TrackerBackend);
    }
    services {
        Aggregator@0x4fe37e07a040ac29,
    }
    types {
        enum TrackerBackend {
            BTree,
            SailsFixed,
        }
    }
}
