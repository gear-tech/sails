
!@sails: 1.0.0-beta.5

service Vft@0x53bb8c1a98387ed4 {
    functions {
        Allowance(owner: ActorId, spender: ActorId) -> U256;
        Approve(spender: ActorId, amount: U256) -> bool;
        BalanceOf(owner: ActorId) -> U256;
        Transfer(to: ActorId, amount: U256) -> bool;
        TransferFrom(owner: ActorId, to: ActorId, amount: U256) -> bool;
    }
}

program MinimalVftSails {
    constructors {
        NewForBench();
    }
    services {
        Vft@0x53bb8c1a98387ed4,
    }
}
