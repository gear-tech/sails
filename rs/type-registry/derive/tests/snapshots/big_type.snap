#[automatically_derived]
impl<
    T: sails_rs::type_info::TypeInfo,
    U: sails_rs::type_info::TypeInfo,
    const SIZE: usize,
> sails_rs::type_info::TypeInfo for Container<T, U, SIZE>
where
    T: Clone,
{
    type Identity = Self;
    fn type_info(
        registry: &mut sails_rs::type_info::Registry,
    ) -> sails_rs::type_info::ty::Type {
        let mut type_builder = sails_rs::type_info::builder::TypeBuilder::new()
            .module_path(::core::module_path!())
            .name("Container")
            .doc("The Container Type");
        {
            let arg_id = { registry.register_type::<T>() };
            type_builder = type_builder.type_param("T").arg(arg_id);
        }
        {
            let arg_id = { registry.register_type::<U>() };
            type_builder = type_builder.type_param("U").arg(arg_id);
        }
        type_builder = type_builder
            .const_param("SIZE")
            .val(sails_rs::type_info::prelude::alloc::format!("{}", SIZE));
        type_builder = type_builder.annotate("attr1").value("val1");
        type_builder = type_builder.annotate("attr2");
        let mut builder = type_builder.composite();
        {
            let ty = {
                let base_id = registry
                    .register_type::<Option<Box<Container<T, U, SIZE>>>>();
                let args = sails_rs::type_info::prelude::alloc::vec![
                    {
                        let base_id = registry
                            .register_type::<Box<Container<T, U, SIZE>>>();
                        let args = sails_rs::type_info::prelude::alloc::vec![
                            {
                                let base_id = registry
                                    .register_type::<Container<T, U, SIZE>>();
                                let args = sails_rs::type_info::prelude::alloc::vec![
                                    registry
                                        .register_type_def(
                                            sails_rs::type_info::ty::Type::builder()
                                                .name("T")
                                                .parameter("T"),
                                        ),
                                    registry
                                        .register_type_def(
                                            sails_rs::type_info::ty::Type::builder()
                                                .name("U")
                                                .parameter("U"),
                                        ),
                                    { registry.register_type::<SIZE>() },
                                ];
                                registry
                                    .register_type_def(
                                        sails_rs::type_info::ty::Type::builder()
                                            .applied(base_id, args),
                                    )
                            },
                        ];
                        registry
                            .register_type_def(
                                sails_rs::type_info::ty::Type::builder()
                                    .applied(base_id, args),
                            )
                    },
                ];
                registry
                    .register_type_def(
                        sails_rs::type_info::ty::Type::builder().applied(base_id, args),
                    )
            };
            builder = builder
                .field("next")
                .type_name(
                    sails_rs::type_info::prelude::alloc::string::String::from(
                        ::core::stringify!(Option < Box < Container < T, U, SIZE > > >),
                    ),
                )
                .doc("Recursive field")
                .ty(ty);
        }
        {
            let ty = {
                let inner_id = registry
                    .register_type_def(
                        sails_rs::type_info::ty::Type::builder().name("T").parameter("T"),
                    );
                registry
                    .register_type_def(
                        sails_rs::type_info::ty::Type::builder()
                            .array(inner_id, SIZE as u32),
                    )
            };
            builder = builder
                .field("data")
                .type_name(
                    sails_rs::type_info::prelude::alloc::string::String::from(
                        ::core::stringify!([T; SIZE]),
                    ),
                )
                .doc("Field with many annotations")
                .annotate("indexed")
                .annotate("secret")
                .value("true")
                .annotate("range")
                .value("0..100")
                .ty(ty);
        }
        {
            let ty = {
                let base_id = registry.register_type::<BTreeMap<String, U>>();
                let args = sails_rs::type_info::prelude::alloc::vec![
                    { registry.register_type::<String>() },
                    registry
                        .register_type_def(
                            sails_rs::type_info::ty::Type::builder()
                                .name("U")
                                .parameter("U"),
                        ),
                ];
                registry
                    .register_type_def(
                        sails_rs::type_info::ty::Type::builder().applied(base_id, args),
                    )
            };
            builder = builder
                .field("mapped")
                .type_name(
                    sails_rs::type_info::prelude::alloc::string::String::from(
                        ::core::stringify!(BTreeMap < String, U >),
                    ),
                )
                .ty(ty);
        }
        {
            let ty = { registry.register_type::<(u32, bool, String)>() };
            builder = builder
                .field("meta")
                .type_name(
                    sails_rs::type_info::prelude::alloc::string::String::from(
                        ::core::stringify!((u32, bool, String)),
                    ),
                )
                .doc("Tuple field")
                .ty(ty);
        }
        builder.build()
    }
}
