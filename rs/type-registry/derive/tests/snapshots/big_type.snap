#[automatically_derived]
impl<
    T: sails_rs::type_info::TypeInfo,
    U: sails_rs::type_info::TypeInfo,
    const SIZE: usize,
> sails_rs::type_info::TypeInfo for Container<T, U, SIZE>
where
    T: Clone,
{
    type Identity = Self;
    fn type_info(
        registry: &mut sails_rs::type_info::Registry,
    ) -> sails_rs::type_info::ty::Type {
        let mut type_builder = sails_rs::type_info::builder::TypeBuilder::new()
            .module_path(::core::module_path!())
            .name("Container")
            .doc("The Container Type")
            .annotate("attr1")
            .value("val1")
            .annotate("attr2");
        type_builder = type_builder.param("T").arg({ registry.register_type::<T>() });
        type_builder = type_builder.param("U").arg({ registry.register_type::<U>() });
        type_builder = type_builder
            .param("SIZE")
            .val(sails_rs::type_info::prelude::alloc::format!("{}", SIZE));
        let mut builder = type_builder.composite();
        builder = builder
            .field("next")
            .doc("Recursive field")
            .ty({
                let base_id = registry
                    .register_type::<Option<Box<Container<T, U, SIZE>>>>();
                let args = sails_rs::type_info::prelude::alloc::vec![
                    { let base_id = registry.register_type:: < Container < T, U, SIZE > >
                    (); let args = sails_rs::type_info::prelude::alloc::vec![registry
                    .register_type_def(sails_rs::type_info::ty::Type::builder().name("T")
                    .parameter("T")), registry
                    .register_type_def(sails_rs::type_info::ty::Type::builder().name("U")
                    .parameter("U"))]; registry
                    .register_type_def(sails_rs::type_info::ty::Type::builder()
                    .applied(base_id, args)) }
                ];
                registry
                    .register_type_def(
                        sails_rs::type_info::ty::Type::builder().applied(base_id, args),
                    )
            });
        builder = builder
            .field("data")
            .doc("Field with many annotations")
            .annotate("indexed")
            .annotate("secret")
            .value("true")
            .annotate("range")
            .value("0..100")
            .ty({
                let inner_id = registry
                    .register_type_def(
                        sails_rs::type_info::ty::Type::builder().name("T").parameter("T"),
                    );
                registry
                    .register_type_def(
                        sails_rs::type_info::ty::Type::builder()
                            .array(inner_id, SIZE as u32),
                    )
            });
        builder = builder
            .field("mapped")
            .ty({
                let base_id = registry.register_type::<BTreeMap<String, U>>();
                let args = sails_rs::type_info::prelude::alloc::vec![
                    { registry.register_type:: < String > () }, registry
                    .register_type_def(sails_rs::type_info::ty::Type::builder().name("U")
                    .parameter("U"))
                ];
                registry
                    .register_type_def(
                        sails_rs::type_info::ty::Type::builder().applied(base_id, args),
                    )
            });
        builder = builder
            .field("meta")
            .doc("Tuple field")
            .ty({ registry.register_type::<(u32, bool, String)>() });
        builder.build()
    }
}
