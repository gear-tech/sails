#[automatically_derived]
impl<T: ::sails_type_registry::TypeInfo> ::sails_type_registry::TypeInfo for Basic<T> {
    type Identity = Self;
    fn type_info(
        registry: &mut ::sails_type_registry::Registry,
    ) -> ::sails_type_registry::ty::Type {
        let mut type_builder = ::sails_type_registry::builder::TypeBuilder::new()
            .module_path(::core::module_path!())
            .name("Basic")
            .docs(
                ::sails_type_registry::prelude::alloc::vec![
                    "Basic struct with docs".to_string(),
                    "Second line of documentation".to_string(),
                ],
            );
        type_builder = type_builder.type_param("T", registry.register_type::<T>());
        type_builder
            .composite()
            .field(
                "a",
                {
                    let id = registry.register_type::<u32>();
                    let field_type = ::sails_type_registry::ty::FieldType::Id(id);
                    registry.expand_aliases(&field_type)
                },
            )
            .type_name(
                ::sails_type_registry::prelude::alloc::string::String::from(
                    ::core::stringify!(u32),
                ),
            )
            .docs(
                ::sails_type_registry::prelude::alloc::vec!["Simple field".to_string()],
            )
            .annotation(
                ::sails_type_registry::ty::Annotation::new_with_value("name", "custom"),
            )
            .field("b", ::sails_type_registry::ty::FieldType::Parameter("T".to_string()))
            .type_name(
                ::sails_type_registry::prelude::alloc::string::String::from(
                    ::core::stringify!(T),
                ),
            )
            .docs(
                ::sails_type_registry::prelude::alloc::vec![
                    "Direct parameter".to_string(),
                ],
            )
            .build()
    }
}
