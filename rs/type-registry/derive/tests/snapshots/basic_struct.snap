#[automatically_derived]
impl<T: ::sails_type_registry::TypeInfo> ::sails_type_registry::TypeInfo for Basic<T> {
    type Identity = Self;
    fn type_info(
        registry: &mut ::sails_type_registry::Registry,
    ) -> ::sails_type_registry::ty::Type {
        let mut type_builder = ::sails_type_registry::builder::TypeBuilder::new()
            .module_path(::core::module_path!())
            .name("Basic")
            .doc("Basic struct with docs")
            .doc("Second line of documentation");
        {
            let arg_id = { registry.register_type::<T>() };
            type_builder = type_builder.type_param("T").arg(arg_id);
        }
        let mut builder = type_builder.composite();
        {
            let ty = { registry.register_type::<u32>() };
            builder = builder
                .field("a")
                .type_name(
                    ::sails_type_registry::prelude::alloc::string::String::from(
                        ::core::stringify!(u32),
                    ),
                )
                .doc("Simple field")
                .annotate("name")
                .value("custom")
                .ty(ty);
        }
        {
            let ty = registry
                .register_type_def(
                    ::sails_type_registry::ty::Type::builder().name("T").parameter("T"),
                );
            builder = builder
                .field("b")
                .type_name(
                    ::sails_type_registry::prelude::alloc::string::String::from(
                        ::core::stringify!(T),
                    ),
                )
                .doc("Direct parameter")
                .ty(ty);
        }
        builder.build()
    }
}
