use ::{{ client_crate_name }}::{
    {{ client_program_name }} as _,
    {{ client_program_name }}Ctors as _,
    {{ service_name_snake }}::*,
};
use sails_rs::prelude::futures::StreamExt as _;
#[allow(unused_imports)]
use sails_rs::{client::*, gtest::*, prelude::*};

#[tokio::test]
async fn do_something_works() {
    // Create Sails Env
    let env = GtestEnv::default();
    let code_id = env.system().submit_code(::{{ program_crate_name }}::WASM_BINARY);

    // Deploy program
    let program = env
        .deploy::<::{{ client_crate_name }}::{{ client_program_name }}Program>(code_id, b"salt".to_vec())
        .create() // Call program's constructor
        .await
        .unwrap();

    // Create service client
    let mut service_client = program.{{ service_name_snake }}();
    
    // Subscribe to service events
    let listener = service_client.listener();
    let mut service_events = listener.listen().await.unwrap();

    // Query service
    let state = service_client.get_state().await.unwrap();
    assert_eq!(None, state.last_caller);

    let result = service_client
        .do_something() // Call service's method
        .await
        .unwrap();

    assert_eq!(result, "Hello from {{ service_name }}!".to_string());

    // Query service
    let state = service_client.get_state().await.unwrap();
    assert_eq!(Some(ActorId::from(DEFAULT_USER_ALICE)), state.last_caller);

    // Read events
    let (actor_id, event) = service_events.next().await.unwrap();
    assert_eq!(program.id(), actor_id);
    assert_eq!(
        events::{{ service_name }}Events::CalledBy {
            caller: ActorId::from(DEFAULT_USER_ALICE)
        },
        event
    );
}
